# ═══════════════════════════════════════════
# Arcaive Environment Configuration
# ═══════════════════════════════════════════

# PageIndex API
PAGEINDEX_API_KEY=your_pageindex_api_key_here

# JWT Authentication
JWT_SECRET_KEY=arcaive-dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000

# Storage (future — S3)
STORAGE_TYPE=local
LOCAL_UPLOAD_DIR=./uploads
