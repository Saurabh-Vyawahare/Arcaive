# ═══════════════════════════════════════════
# Arcaive Environment Configuration
# ═══════════════════════════════════════════

# Supabase (supabase.com → Settings → API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJ...your-legacy-service-role-key

# OpenAI (used by PageIndex for tree generation + queries)
CHATGPT_API_KEY=sk-your-openai-key-here

# JWT Authentication
JWT_SECRET_KEY=arcaive-dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:3000

# Storage
UPLOAD_DIR=./uploads
